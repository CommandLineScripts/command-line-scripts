{
  "name": "clscripts",
  "private": true,
  "license": "Apache-2.0",
  "description": "Type-safe, composable classes to build and run CLI commands programmatically.",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "clean": "turbo run clean && del \"./{node_modules,.turbo,pnpm-lock.yaml}\"",
    "create-package": "pnpm --filter @clscripts/cli start"
  },
  "devDependencies": {
    "@homer0/prettier-plugin-jsdoc": "^12.0.0",
    "@types/node": "^24.0.10",
    "del-cli": "^6.0.0",
    "prettier": "3.7.3",
    "prettier-plugin-jsdoc": "1.3.3",
    "prettier-plugin-tailwindcss": "0.6.13",
    "turbo": "^2.5.4",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "engines": {
    "node": ">=18"
  }
}
